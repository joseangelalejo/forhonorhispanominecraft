# ==============================
# Public template for local setup
# Copy this file to .env and set your own values.
# ==============================

MC_IMAGE=itzg/minecraft-server:latest
MC_CONTAINER_NAME=minecraft-server

MC_PORT_TCP=25565
MC_PORT_UDP_BEDROCK=19133
MC_RCON_PORT=25575

EULA=TRUE
TYPE=FABRIC
VERSION=1.20.1
MEMORY=7G
MOTD=A For Honor RPG Server
ONLINE_MODE=false
USE_AIKAR_FLAGS=true
USE_MEOWICE_FLAGS=true
FORCE_GAMEMODE=true
SIMULATION_DISTANCE=10
VIEW_DISTANCE=10
LEVEL=forhonorhispano
SPAWN_PROTECTION=180
OPS=MiniatureMistery

ENABLE_RCON=true
RCON_PASSWORD=CHANGE_ME_STRONG_PASSWORD
RCON_CMDS_STARTUP=say Server iniciado, esperando jugadores...
RCON_CMDS_ON_CONNECT=say Bienvenido al server, %player%!
RCON_CMDS_FIRST_CONNECT=forceload add -500 -500 500 500
RCON_CMDS_LAST_DISCONNECT=say Shutting down server
PLAYER_IDLE_TIMEOUT=10

SERVER_NAME=forhonorhispano
BUG_REPORT_LINK=minecraft.forhonorhispano.com
MANAGEMENT_SERVER_ENABLED=true
MANAGEMENT_SERVER_HOST=minecraft.forhonorhispano.com
MANAGEMENT_SERVER_PORT=10110
MANAGEMENT_SERVER_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
